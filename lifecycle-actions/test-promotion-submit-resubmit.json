{
  "version": "1",
  "name": "Promotion claim CREATE + owner RESUBMIT as a fresh non-admin wallet (reproduces Rewards page submit flow)",
  "actors": {
    "User": "91d9zpdo6X33H6kBkFQzYpRWmAZxEV2zhUnrjidtmFCW"
  },
  "steps": [
    { "op": "as", "who": "User" },

    { "op": "set", "path": "promotionClaims/$User", "data": {
      "userAddress": "$User",
      "link": "https://x.com/aeonian/status/123",
      "status": "pending",
      "pointsAwarded": 1000,
      "createdAt": "@time.now",
      "updatedAt": "@time.now"
    } },
    { "op": "expect", "expr": "get(/promotionClaims/$User).status == 'pending'" },
    { "op": "expect", "expr": "get(/promotionClaims/$User).link == 'https://x.com/aeonian/status/123'" },

    { "op": "as", "who": "User" },
    { "op": "set", "path": "promotionClaims/$User", "data": {
      "link": "https://x.com/aeonian/status/456",
      "status": "pending",
      "updatedAt": "@time.now"
    } },
    { "op": "expect", "expr": "get(/promotionClaims/$User).status == 'pending'" },
    { "op": "expect", "expr": "get(/promotionClaims/$User).link == 'https://x.com/aeonian/status/456'" }
  ]
}
