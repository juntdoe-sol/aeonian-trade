# Copy this file to .env and fill in your values
# Do NOT commit .env to git

# Whether to show a preview bar in the UI (true/false)
VITE_SHOW_PREVIEW_BAR=false

# Your Tarobase app ID
VITE_TAROBASE_APP_ID=your_tarobase_app_id_here

# Solana RPC endpoint (e.g. from Helius, QuickNode, or official mainnet)
VITE_RPC_URL=https://your-rpc-endpoint.com

# Chain mode (e.g. mainnet-beta)
VITE_CHAIN=mainnet-beta
